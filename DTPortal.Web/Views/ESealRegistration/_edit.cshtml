        $("#SignatoryEmail").typeahead({
            minLength: 3,
            items: 5,
            source: function (request, response) {
                $.ajax({
                    url: '@Url.Action("GetActiveSubscribersEmailList", "ESealRegistration")',
                    data: { "value": request },
                    type: "GET",
                    contentType: "json",
                    error: ajaxErrorHandler,
                    success: function (data) {
                        items = [];
                        map = {};
                        $.each(data, function (i, item) {
                            var id = i;
                            var name = item;
                            map[name] = {
                                id: id,
                                name: name
                            };
                            items.push(name);
                        });
                        response(items);
                    }
                });
            },
        });

