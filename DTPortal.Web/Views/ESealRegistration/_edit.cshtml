        {
            'organizationUID': organizationUID,
            'organizationName': organizationName,
            'emails': subscriberArray,
            'transactionId': "",
            'enablePostPaidOption': "",
            'signedPdf': null,
            'ESealActionMethod': 'update_wallet'
        };

        verifyDocumentCall(data);
    }




